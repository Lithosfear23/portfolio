                                                </svg>
                                                <div class="ps-1">
                                                    @((selectedProjectModel.Medias.Count - mediaCount) - 1)
                                                </div>
                                            </div>
                                        </button>
                                    </div>
                                }
                                
                            </div>
                        </div>
                        <div class="mx-auto flex flex-col items-center justify-center font-body
