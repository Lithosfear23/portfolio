                    }
                </div>
                
                <div class="flex flex-col md:flex-row flex-wrap justify-center gap-8 max-w-4xl mx-auto pt-2 px-3 font-body text-slate-300">
                    @foreach (var channel in contactModel?.ContactChannels)
                    {
                        <a 
                            href="@channel.ChannelLink"
                           class="flex flex-col md:w-[350px] md:h-15 gap-3 rounded-2xl py-3 px-2 border border-blue-400 overflow-y-auto
