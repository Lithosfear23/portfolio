@code {
    //Models
    private List<ProjectYears> projectYears = new();
    private ProjectsModel? selectedProjectModel;
    private ProjectMedia? selectedProjectMedia;
    private ProjectMedia? selectedGalleryProjectMedia;

    //Dictionaries
    private Dictionary<int, List<ProjectsModel>> projectsModels = new();

    //Strings
    private string projectSelectedYear = "";

    //Int
    private int selectedYear = 0;
    private int projectModelIndex = 0;
    private int projectMediaIndex = 0;
    private int displayedMedia = 0;

    //Const
    private const int MAX_DISPLAYED_MEDIA = 4;

    //Bool
    private bool isSelectedProjectYear = false;
    private bool isVideoSelected = true;
    private bool isGalleryOpened = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            PopulateYearStore();
            PopulateProjectStore();

            var width = await JS.InvokeAsync<int>("GetWindowSize");

            displayedMedia = width <= 320 ? MAX_DISPLAYED_MEDIA - 1 : MAX_DISPLAYED_MEDIA;

            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SwitchSelectedProjectYear(int year)
    {
        foreach (var projYear in projectYears)
        {
            if (projYear.Year == year) projYear.Selected = true;
            else projYear.Selected = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void PopulateYearStore()
    {
        for (int i = 1; i < 5; i++)
        {
            projectYears.Add(
                new ProjectYears
                {
                    Year = i
                }
            );
        }

        selectedYear = projectYears.Select(t => t.Year).FirstOrDefault();
    }

    private void PopulateProjectStore()
    {
        List<ProjectsModel> yearOneProjectModels = new List<ProjectsModel>
        {

            new ProjectsModel
            {
                Date = DateTime.TryParseExact("02-03-26", "MM-dd-yy", CultureInfo.InvariantCulture, DateTimeStyles.None,
                out var date) ? date : DateTime.Today,
                ProjectName = "4 Pics 1 Word",
                ProjectStatus = "Complete",
                TechStack = new List<string>
                {
                    "Python", "Tkinter"
                },
                Medias = new List<ProjectMedia>
                {
                    new (key: 0, source: "/projects/year-1/4-pics-1-word/4-pics-1-word-gameplay-demo.mp4", type: FileTypes.MP4, isVideo: true),
                    new (key: 1, source: "/projects/year-1/4-pics-1-word/4-pics-1-word-thumb-1.png", type: FileTypes.PNG),
                    new (key: 2, source: "/projects/year-1/4-pics-1-word/4-pics-1-word-thumb-2.png", type: FileTypes.PNG),
                    new (key: 3, source: "/projects/year-1/4-pics-1-word/4-pics-1-word-thumb-3.png", type: FileTypes.PNG),
                    new (key: 4, source: "/projects/year-1/4-pics-1-word/4-pics-1-word-thumb-4.png", type: FileTypes.PNG),
                    new (key: 5, source: "/projects/year-1/4-pics-1-word/4-pics-1-word-thumb-5.png", type: FileTypes.PNG),
                    new (key: 6, source: "/projects/year-1/4-pics-1-word/4-pics-1-word-thumb-6.png", type: FileTypes.PNG),
                    new (key: 7, source: "/projects/year-1/4-pics-1-word/4-pics-1-word-video-thumb.png", type: FileTypes.PNG, isVideo: true),
                },
                Description = """"
                A desktop word puzzle game developed in Python using Tkinter, inspired by the popular mobile game "4 Pics 1 Word". 
                This was the very first complete project I built and marked the beginning of my software development journey.
                """"
            }

        };

