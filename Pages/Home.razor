@using System.Globalization
@page "/"
@inject IJSRuntime JS

<PageTitle>Renz Malabanan</PageTitle>

<!--

    DEFAULT STYLING

    FONT-HERO text-5xl sm:text-6xl md:text-7xl uppercase
    FONT-HEADING text-center md:text-start text-blue-400 tracking-[0.3em]
    FONT-BODY text-center md:text-start text-lg leading-6 text-slate-300
    PRIMARY BUTTON  bg-blue-500 hover:bg-blue-400 hover:shadow-lg hover:-translate-y-1 text-white 
                    py-3 px-5 rounded-md font-body transition-all duration-200
    SECONDARY BUTTON  border border-blue-400 text-blue-400 hover:text-white hover:shadow-lg hover:border-white hover:-translate-y-1
                      py-3 px-3 rounded-md transition-all duration-200

-->

<!-- HOME SECTION -->
<section 
    id="home"
    class="min-h-screen flex flex-col md:flex-row justify-center items-center gap-12 pt-8">

    <div class="mx-auto w-full md:ps-20 max-w-7xl space-y-3">
        
        <p class="font-heading text-sm text-center md:text-start text-blue-400 tracking-[0.3em]"> > Loading player 016...</p>

        <div class="text-center md:text-start">
            <h1 class="inline-block font-hero text-5xl sm:text-6xl md:text-7xl uppercase px-2 md:px-0">@heroModel?.HeroName</h1>
        </div>

        <p class="font-heading text-xl text-blue-400 text-center md:text-start uppercase tracking-[0.3em]">@heroModel?.HeroTitle</p>

        <p class="font-body text-center md:text-start text-lg leading-6 text-slate-300 break-nromal px-3 md:px-0">
            @heroModel?.HeroDescription
        </p>

        <div class="flex flex-row justify-center md:justify-start gap-3 mt-8">

            <a 
                href="#projects"
                class="bg-blue-500 hover:bg-blue-400 hover:shadow-lg hover:-translate-y-1 text-white 
                py-3 px-5 rounded-md font-body transition-all duration-200">
                View Projects
            </a>

            <a 
                href="/hero/hero-resume-malabanan.pdf"
                target="_blank"
               class="border border-blue-400 hover:border-cyan-300 hover:shadow-[0_0_18px_rgba(59,130,246,0.35)]  hover:-translate-y-1
                py-3 px-3 rounded-md transition-all duration-200">
                View Resume
            </a>

        </div>

    </div>

    <div class="mx-auto w-75 md:w-1/2 max-w-3xl px-6">

        <img 
            class="border border-blue-400 rounded-2xl"
            src="@heroModel?.HeroImage" />

    </div>

</section>

<!-- ABOUT SECTION -->
<section 
    id="about"
    class="min-h-screen flex flex-col md:flex-row justify-center items-center py-16">

    <div class="w-full max-w-7xl space-y-8">

        <p class="font-heading text-sm text-center md:text-start text-blue-400 tracking-[0.3em]"> > Character Sheet</p>
        
        <div class="text-center">
        
            <h1 class="inline-block font-heading text-5xl sm:text-6xl md:text-7xl uppercase">About</h1>

        </div>

        <div class="max-w-3xl mx-auto text-center font-body text-slate-300 text-lg space-y-3 leading-6">
            @if (aboutModel != null)
            {
                @foreach (var description in aboutModel.DescriptionParagraphs)
                {
                    <div class="px-3">
                        @description
                    </div>
                }

                <div class="font-heading text-sm text-center text-blue-400 tracking-[0.3em] pt-8">
                    > Skills Unlocked:
                </div>

                <div class="flex flex-wrap items-center justify-center gap-4">
                    @foreach (var skill in aboutModel.Skills)
                    {
                        <div class="border border-blue-400 hover:border-cyan-300 hover:shadow-[0_0_18px_rgba(59,130,246,0.35)] hover:-translate-y-1 flex items-center justify-center
                             w-30 h-8 text-center rounded-md font-body transition-all duration-200">
                            @skill
                        </div>
                    }
                </div>
            }
            else
            {
                <div>
                    Nothing to display.
                </div>
                <div class="font-heading text-sm text-center text-blue-400 tracking-[0.3em] pt-8">
                    > Skills Unlocked:
                </div>
                <div>
                    Nothing to display.
                </div>
            }
        </div>

    </div>

</section>

<!-- PROJECTS SECTION -->
<section 
    id="projects"
    class="min-h-screen flex flex-col md:flex-row justify-center items-center py-16">

    <div class="w-full max-w-6xl space-y-8">
        
        <p class="font-heading text-sm text-center md:text-start text-blue-400 tracking-[0.3em]"> > Completed Quests</p>

        <div class="text-center">

            <h1 class="inline-block font-heading text-5xl sm:text-6xl md:text-7xl uppercase">Projects</h1>

        </div>

        <p class="font-heading text-sm text-center text-blue-400 tracking-[0.3em]"> > Main Quest</p>

        <div class="flex items-center justify-center">
            <div class="w-fit p-4">

                <h1 class="inline-block font-body text-slate-300 text-3xl
                    duration-200 hover:shadow-lg
                    hover:-translate-y-1 border-b border-blue-400 shadow-xl/50  shadow-sky-500
                    md:text-4xl uppercase font-bold">PlanterAid</h1>
            </div>
        </div>

        <div class="flex flex-col items-center text-start font-body text-slate-300 text-lg space-y-3 leading-6 px-3">

            <div class="flex flex-col gap-3 rounded-2xl py-3 px-2">

                <div class="flex justify-between border border-blue-400 text-blue-400 rounded-2xl py-3 px-2">
                    <button class="flex justify-center items-center"
                            @onclick="async () => await SwitchSelectedProject(selectedYear, SlideDirections.Next)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                             class="icon icon-tabler icons-tabler-outline icon-tabler-arrow-badge-left
                                             cursor-pointer transition-all duration-200 hover:shadow-lg hover:-translate-y-1">
                            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                            <path d="M11 17h6l-4 -5l4 -5h-6l-4 5l4 5" />
                        </svg>
                    </button>
                    <div class="flex justify-center">
                        @if (isCapstoneVideoSelected)
                        {
                            <video @key="selectedCapstoneProjectMedia?.Source" autoplay muted loop playsinline controls>
                                <source src="@selectedCapstoneProjectMedia?.Source">
                            </video>
                        }
                        else
                        {
                            <img src="@selectedCapstoneProjectMedia?.Source" />
                        }
                    </div>
                    <button class="flex justify-center items-center"
                            @onclick="async () => await SwitchSelectedProject(selectedYear, SlideDirections.Next)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                             class="icon icon-tabler icons-tabler-outline icon-tabler-arrow-badge-right
                                            cursor-pointer transition-all duration-200 hover:shadow-lg hover:-translate-y-1">
                            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                            <path d="M13 7h-6l4 5l-4 5h6l4 -5l-4 -5" />
                        </svg>
                    </button>
                </div>

                <div class="flex gap-2 text-blue-400 rounded-2xl overflow-y-hidden overflow-x-auto py-4 ">
                    @foreach (var media in capstoneProjectModel.Medias.OrderByDescending(t => t.IsVideo))
                    {
                        var isVideoThumb = media.IsVideo && media.Type == FileTypes.PNG;

                        if (isVideoThumb)
                        {
                            <div class="relative w-28 h-12 group transition-all duration-200
                                        hover:shadow-lg hover:-translate-y-1">
                                <button class="relative w-full h-full cursor-pointer" @onclick="() => SwitchCapstoneMedia(media.Key)">
                                    @if (isCapstoneVideoSelected)
                                    {
                                        <img class="w-full h-full object-cover border-b border-blue-400 shadow-xl/15 shadow-sky-300"
                                             src="@media.Source" />
                                    }
                                    else
                                    {
                                        <img class="w-full h-full"
                                             src="@media.Source" />
                                    }

                                    <div class="absolute inset-0 flex items-center justify-center text-slate-300">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                             fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-player-play">
                                            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                            <path d="M6 4v16a1 1 0 0 0 1.524 .852l13 -8a1 1 0 0 0 0 -1.704l-13 -8a1 1 0 0 0 -1.524 .852z" />
                                        </svg>
                                    </div>
                                </button>
                            </div>
                        }
                        else if (!media.IsVideo && media.Type == FileTypes.PNG)
                        {
                            @if (media.Key == selectedCapstoneProjectMedia?.Key)
                            {
                                <img class="w-28 h-12 cursor-pointer transition-all duration-200 hover:shadow-lg
                                     hover:-translate-y-1 border-b border-blue-400 shadow-xl/15 shadow-sky-300"
                                     src="@media.Source"
                                     @onclick="() => SwitchCapstoneMedia(media.Key)" />
                            }
                            else {
                                <img class="w-28 h-12 cursor-pointer transition-all duration-200 hover:shadow-lg
                                     hover:-translate-y-1"
                                     src="@media.Source"
                                     @onclick="() => SwitchCapstoneMedia(media.Key)" />
                            }
                        }
                    }
                </div>
            </div>

            <div class="md:grid md:grid-cols-[180px_1fr] gap-x-4 gap-y-3
                        border border-blue-400 rounded-2xl p-3 font-body text-slate-300">

                <div class="font-bold underline">Description:</div>

                    <div class="leading-6">
                        @capstoneProjectModel.Description
                    </div>

            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto pt-2 font-body text-slate-300">

                <div class="flex flex-col md:w-[350px] gap-3 rounded-2xl scrollbar-thin
                    py-3 px-2 border border-blue-400 overflow-y-auto scroll-smooth scrollbar-thumb-blue-400">

                    <div class="text-2xl text-center font-bold">
                        Features
                    </div>

                    <div class="flex flex-wrap justify-center gap-3">
                        @foreach (var feature in capstoneProjectModel.FeaturesList)
                        {
                            <div class="border border-blue-400 hover:border-cyan-300 hover:shadow-[0_0_18px_rgba(59,130,246,0.35)] hover:-translate-y-1 text-white flex items-center
                                justify-center w-auto h-auto p-2 text-center rounded-md font-body cursor-pointer transition-all duration-200">
                                @feature
                            </div>
                        }
                    </div>

                </div>
                <div class="flex flex-col md:w-[350px] gap-3 rounded-2xl scrollbar-thin
                    py-3 px-2 border border-blue-400 overflow-y-auto scroll-smooth scrollbar-thumb-blue-400">

                    <div class="text-2xl text-center font-bold">
                        Powered By
                    </div>

                    <div class="flex flex-wrap justify-center gap-3">
                        @foreach (var tech in capstoneProjectModel.TechStack)
                        {
                            <div class="border border-blue-400 hover:border-cyan-300 hover:shadow-[0_0_18px_rgba(59,130,246,0.35)] hover:-translate-y-1 text-white flex items-center
                                justify-center w-30 h-auto text-center rounded-md font-body cursor-pointer transition-all duration-200">
                                @tech
                            </div>
                        }
                    </div>

                </div>
                <div class="flex items-center justify-center">
                    <div class="flex flex-col md:w-30 md:max-h-30 gap-3 rounded-2xl py-3 px-2 border border-blue-400 overflow-y-auto">

                        <div class="text-2xl text-center font-bold">
                            Status
                        </div>

                        <div class="flex flex-wrap justify-center gap-3">

                            <div class="bg-green-500 hover:bg-green-400 hover:shadow-lg hover:-translate-y-1 text-white flex items-center
                            justify-center w-30 h-5 text-center rounded-md font-body cursor-pointer transition-all duration-200 uppercase">
                                @capstoneProjectModel.ProjectStatus
                            </div>

                        </div>

                    </div>

                </div>
                <div class="flex items-center justify-center">
                    <div class="flex flex-col md:w-50 md:max-h-35 gap-3 rounded-2xl py-3 px-2 border border-blue-400 overflow-y-auto">

                        <div class="text-2xl text-center font-bold">
                            Completed On
                        </div>

                        <div class="flex flex-wrap justify-center gap-3">

                            <div class="border border-blue-400 hover:border-cyan-300 hover:shadow-[0_0_18px_rgba(59,130,246,0.35)] hover:-translate-y-1 text-white flex items-center
                            justify-center w-35 h-5 text-center rounded-md font-body px-1 cursor-pointer transition-all duration-200">
                                @capstoneProjectModel.Date.ToString("MMMM yyyy")
                            </div>

                        </div>

                    </div>

                </div>
                
            </div>

        </div>

        <p class="font-heading text-sm text-center text-blue-400 tracking-[0.3em]"> > Side Quests</p>
        
        <div class="flex flex-col mx-auto md:w-3xl lg:w-5xl rounded-2xl gap-8 border border-blue-400">

            <div class="flex justify-center pt-3">
                
                <div class="flex justify-between px-3 md:w-160 border border-blue-400 rounded-2xl">

                    @foreach (var year in projectYears)
                    {
                        <div class="
                            text-center w-15 rounded-2xl hover:text-white
                            hover:shadow-lg cursor-pointer transition-all duration-200 hover:border-white hover:-translate-y-1 "
                             @onclick="async () => await SwitchSelectedProjectYear(year.Year)">
                            @if (year.Year == selectedYear)
                            {
                                <div class="underline underline-offset-3 decoration-1 decoration-slate-300">
                                    Year @year.Year
                                </div>
                            }
                            else
                            {
                                <div>
                                    Year @year.Year
                                </div>
                            }
                        </div>
                    }

                </div>

            </div>

            <div class="flex flex-col justify-between py-3 px-1.25 md:px-3 gap-5">
                @if (selectedProjectModel != null)
                {
                    var mediaCount = Math.Min(displayedMedia - 1, selectedProjectModel.Medias.Count);
                    var videoMedia = selectedProjectModel.Medias.Where(t => t.IsVideo).FirstOrDefault();
                    var videoThumb = selectedProjectModel.Medias
                        .Where(t => t.IsVideo && t.Type == FileTypes.PNG)
                        .FirstOrDefault();

                    <div class="flex flex-col md:flex-row justify-between gap-1.5 md:gap-2">
                        <div class="mx-auto flex flex-col gap-2">
                            <div class="flex justify-between border border-blue-400 font-bold rounded-2xl py-3 px-2">
                                <button class="flex justify-center items-center"
                                        @onclick="async () => await SwitchSelectedProject(selectedYear, SlideDirections.Next)">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                         class="icon icon-tabler icons-tabler-outline icon-tabler-arrow-badge-left
                                         cursor-pointer transition-all duration-200 hover:shadow-lg hover:-translate-y-1">
                                        <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                        <path d="M11 17h6l-4 -5l4 -5h-6l-4 5l4 5" />
                                    </svg>
                                </button>
                                <div class="flex justify-center">
                                    @if (isVideoSelected)
                                    {
                                        <video @key="videoMedia?.Source" autoplay muted loop playsinline controls>
                                            <source src="@videoMedia?.Source">
                                        </video>
                                    }
                                    else
                                    {
                                        <img src="@selectedProjectMedia?.Source" />
                                    }
                                </div>
                                <button class="flex justify-center items-center" 
                                        @onclick="async () => await SwitchSelectedProject(selectedYear, SlideDirections.Next)">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                         class="icon icon-tabler icons-tabler-outline icon-tabler-arrow-badge-right
                                        cursor-pointer transition-all duration-200 hover:shadow-lg hover:-translate-y-1">
                                        <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                        <path d="M13 7h-6l4 5l-4 5h6l4 -5l-4 -5" />
                                    </svg>
                                </button>
                            </div>
                            <div class="flex justify-center items-center gap-5 py-3 px-2 border border-blue-400 text-blue-400 rounded-2xl">
                                <div class="relative w-28 h-12 group transition-all duration-200
                                    hover:shadow-lg hover:-translate-y-1">
                                    <button class="relative w-full h-full cursor-pointer" @onclick="() => SwitchSelectedMedia(videoThumb.Key)">
                                        @if (selectedProjectMedia.IsVideo)
                                        {
                                            <img class="w-full h-full object-cover border-b border-blue-400 shadow-xl/15 shadow-sky-300"
                                                 src="@videoThumb?.Source" />
                                        }
                                        else
                                        {
                                            <img class="w-full h-full"
                                                 src="@videoThumb?.Source" />
                                        }

                                        <div class="absolute inset-0 flex items-center justify-center text-slate-300">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                                 fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-player-play">
                                                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                                <path d="M6 4v16a1 1 0 0 0 1.524 .852l13 -8a1 1 0 0 0 0 -1.704l-13 -8a1 1 0 0 0 -1.524 .852z" />
                                            </svg>
                                        </div>
                                    </button>
                                </div>

                                @for (int i = 0; i < mediaCount; i++)
                                {
                                    var media = selectedProjectModel.Medias[i];

                                    if (media.Source != videoMedia?.Source && media.Source != videoThumb?.Source)
                                    {
                                        if (selectedProjectMedia.Key == media.Key)
                                        {
                                            <img class="w-28 h-12 cursor-pointer transition-all duration-200 hover:shadow-lg
                                                 hover:-translate-y-1 border-b border-blue-400 shadow-xl/15 shadow-sky-300"
                                                 src="@media.Source" 
                                                 @onclick="() => SwitchSelectedMedia(media.Key)"/>
                                            
                                        }
                                        else {
                                            <img class="w-28 h-12 cursor-pointer transition-all duration-200 hover:shadow-lg
                                                 hover:-translate-y-1"
                                                 src="@media.Source" 
                                                 @onclick="() => SwitchSelectedMedia(media.Key)"/>
                                        }
                                    }
                                }

                                @if (selectedProjectModel.Medias.Count > mediaCount)
                                {
                                    <div class="relative w-28 h-12 bg-black/90 group cursor-pointer transition-all duration-200
                                            hover:shadow-lg hover:-translate-y-1">
                                        <button @onclick="() => ToggleGalleryView(true, mediaCount)">
                                            <img class="w-full h-full blur-sm"
                                                 src="@selectedProjectModel.Medias[mediaCount].Source" />

                                            <div class="absolute inset-0 flex items-center justify-center text-slate-300">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                                     fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round"
                                                     stroke-linejoin="round"
                                                     class="icon icon-tabler icons-tabler-outline icon-tabler-square-plus">
                                                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                                    <path d="M9 12h6" />
                                                    <path d="M12 9v6" />
                                                    <path d="M3 5a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v14a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-14" />
                                                </svg>
                                                <div class="ps-1">
                                                    @((selectedProjectModel.Medias.Count - mediaCount) - 1)
                                                </div>
                                            </div>
                                        </button>
                                    </div>
                                }
                                
                            </div>
                        </div>
                        <div class="mx-auto flex flex-col items-center justify-center font-body
                            p-3 border border-blue-400 rounded-2xl gap-3">
                            <div class="underline underline-offset-3 decoration-1 decoration-slate-300 font-bold">Powered By: </div>
                            <div class="flex flex-wrap justify-center gap-3">
                                @foreach (var tech in selectedProjectModel.TechStack)
                                {
                                    <div class="border border-blue-400 hover:border-cyan-300 hover:shadow-[0_0_18px_rgba(59,130,246,0.35)] hover:-translate-y-1 text-white flex items-center
                                        justify-center w-22 h-auto text-center rounded-md font-body cursor-pointer transition-all duration-200">
                                        @tech
                                    </div>
                                }
                            </div>
                            <div class="underline underline-offset-3 decoration-1 decoration-slate-300 font-bold">Status: </div>
                            <div class="border border-blue-400 hover:border-cyan-300 hover:shadow-[0_0_18px_rgba(59,130,246,0.35)] hover:-translate-y-1 text-white flex items-center
                                justify-center w-22 h-4 text-center rounded-md font-body cursor-pointer transition-all duration-200 p-3">
                                @selectedProjectModel.ProjectStatus
                            </div>
                        </div>
                    </div>

                    <div class="md:grid md:grid-cols-[180px_1fr] gap-x-4 gap-y-3
                        border border-blue-400 rounded-2xl p-3
                        font-body">

                        <div class="font-bold underline">Title:</div>
                        <div class="text-slate-300">@selectedProjectModel.ProjectName</div>

                        <div class="font-bold underline">Description:</div>
                        <div class="max-h-24 overflow-y-auto text-slate-300">
                            @selectedProjectModel.Description
                        </div>

                        <div class="font-bold underline">Features:</div>
                        <div class="max-h-24 overflow-y-auto text-slate-300">
                            @selectedProjectModel.Features
                        </div>

                        <div class="font-bold underline">Credits:</div>
                        <div class="max-h-24 overflow-y-auto text-slate-300">
                            @selectedProjectModel.Credits
                        </div>

                    </div>
                }
                else
                {
                    <h1 class="font-body text-3xl text-slate-300 font-bold">Nothing to display.</h1>
                }

            </div>

        </div>

    </div>

</section>

<!-- EXPERIENCE SECTION -->
<section 
    id="experience"
    class="min-h-screen flex flex-col md:flex-row justify-center items-center py-16">

    <div class="w-full max-w-7xl space-y-8">

        <p class="font-heading text-sm text-center md:text-start text-blue-400 tracking-[0.3em]"> > Achievements</p>

        <div class="text-center px-3">

            <h1 class="inline-block font-heading text-5xl sm:text-6xl md:text-7xl uppercase">Experience</h1>
        
        </div>

        <p class="font-heading text-sm text-center text-blue-400 tracking-[0.3em]"> > Career Logs</p>

        <div class="flex flex-col mx-auto md:w-3xl lg:w-5xl rounded-2xl gap-8 border border-blue-400">

            <div class="flex flex-col max-h-125 md:flex-row justify-between py-3 px-2 md:px-3 gap-5">
                
                <div class="flex flex-col gap-3 md:w-75 h-60 md:h-full overflow-y-auto scrollbar-thin scrollbar-thumb-blue-400 scroll-smooth pe-3">         
                    @foreach (var careerLog in careerLogsModels.Values.OrderByDescending(t => t.EndDate))
                    {
                        var startDate = careerLog.StartDate.ToString("MMM yyyy");
                        var endDate = careerLog.EndDate.ToString("MMM yyyy");

                        @if (careerLog.Key == selectedCareerLogsModel?.Key)
                        {
                            <button class="cursor-pointer transition-all duration-200 hover:shadow-lg ps-3 
                                    hover:-translate-y-1 bg-blue-500/10 font-semibold border-l-2 border-blue-400"
                                    @onclick="() => SwitchSelectedCareer(careerLog.Key)">
                                @startDate - @endDate
                            </button>
                        }
                        else
                        {
                            <button class="cursor-pointer transition-all duration-200 hover:shadow-lg ps-3
                                    hover:-translate-y-1 bg-blue-500/10"
                                    @onclick="() => SwitchSelectedCareer(careerLog.Key)">
                                @startDate - @endDate
                            </button>
                        }
                    }
                </div>

