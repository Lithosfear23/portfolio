                                                 src="@selectedProjectModel.Medias[mediaCount]" />

                                            <div class="absolute inset-0 flex items-center justify-center text-slate-300">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                                     fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round"
                                                     stroke-linejoin="round"
                                                     class="icon icon-tabler icons-tabler-outline icon-tabler-square-plus">
                                                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                                    <path d="M9 12h6" />
                                                    <path d="M12 9v6" />
                                                    <path d="M3 5a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v14a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-14" />
                                                </svg>
                                                <div class="ps-1">
                                                    @(selectedProjectModel.Medias.Count - mediaCount)
                                                </div>
                                            </div>
                                        </button>
                                    </div>
                                }
                                
                            </div>
                        </div>
                        <div class="mx-auto flex flex-col items-center justify-center font-body
                            text-slate-300 p-3 border border-blue-400 text-blue-400 rounded-2xl gap-3">
                            <div class="underline underline-offset-3 decoration-1 decoration-slate-300 font-bold">Powered By: </div>
                            <div class="flex flex-wrap justify-center gap-3">
                                @foreach (var tech in selectedProjectModel.TechStack)
                                {
                                    <div class="bg-blue-500 hover:bg-blue-400 hover:shadow-lg hover:-translate-y-1 text-white flex items-center
                                        justify-center w-22 h-4 text-center rounded-md font-body cursor-pointer transition-all duration-200">
                                        @tech
                                    </div>
                                }
                            </div>
                            <div class="underline underline-offset-3 decoration-1 decoration-slate-300 font-bold">Status: </div>
                            <div class="bg-blue-500 hover:bg-blue-400 hover:shadow-lg hover:-translate-y-1 text-white flex items-center
                                justify-center w-22 h-4 text-center rounded-md font-body cursor-pointer transition-all duration-200">
                                @selectedProjectModel.ProjectStatus
                            </div>
                        </div>
                    </div>

                    <div class="mx-auto flex flex-col w-full justify-center font-body text-slate-300 border border-blue-400
                        text-blue-400 rounded-2xl p-3 gap-3">
                        <div class="flex flex-row gap-4">
                            <div class="underline underline-offset-3 decoration-1 decoration-slate-300 font-bold">Project Title: </div>
                            <div>@selectedProjectModel.ProjectName</div>
                        </div>
                        <div class="flex flex-row max-h-[100px] gap-4">
                            <div class="underline underline-offset-3 decoration-1 decoration-slate-300 font-bold">Project Description: </div>
                            <div class="overflow-y-auto scroll-smooth scrollbar-thumb-blue-400">
                                @selectedProjectModel.Description
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <h1 class="font-body text-3xl text-slate-300 font-bold">Nothing to display.</h1>
                }

            </div>

        </div>

    </div>

</section>

