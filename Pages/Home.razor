    <div class="w-full max-w-7xl space-y-8">
       
        <p class="font-heading text-sm text-center md:text-start text-blue-400 tracking-[0.3em]"> > Communication Terminal</p>

        <div class="text-center px-3">

            <h1 class="inline-block font-heading text-5xl sm:text-6xl md:text-7xl uppercase">Contact</h1>

            <p class="font-body text-2xl text-slate-300 py-3">
                @foreach (var text in contactModel?.MainDescriptionParagraphs)
                {
                    <div>
                        @text
                    </div>
                }
            </p>

            <div class="max-w-3xl mx-auto text-center font-body text-slate-300 text-lg space-y-3 leading-6">

                <div>
                    @foreach (var text in contactModel?.SubDescriptionParagraphs)
                    {
                        <div>
                            @text
