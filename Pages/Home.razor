                                    hover:shadow-lg hover:-translate-y-1">
                                    <button class="relative w-full h-full cursor-pointer" @onclick="() => SwitchSelectedMedia(videoThumb.Key)">
                                        @if (selectedProjectMedia.IsVideo)
                                        {
                                            <img class="w-full h-full object-cover border-b border-blue-400 shadow-xl/15 shadow-sky-300"
                                                 src="@videoThumb?.Source" />
                                        }
                                        else
                                        {
                                            <img class="w-full h-full"
                                                 src="@videoThumb?.Source" />
                                        }

                                        <div class="absolute inset-0 flex items-center justify-center text-slate-300">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
