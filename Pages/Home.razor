    private async Task SwitchSelectedProjectYear(int year)
    {
        selectedYear = year;

        await SwitchSelectedProject(selectedYear, SlideDirections.None);

        await InvokeAsync(StateHasChanged);
    }

    public async Task SwitchSelectedProject(int year, SlideDirections direction)
    {
        if (projectsModels.TryGetValue(year, out var model))
        {
            if (model == null) return;

            // -1 is to ensure that the length is accounting for index 0
            var length = model.Count - 1;

            if (direction == SlideDirections.Next) projectModelIndex++;
            else if (direction == SlideDirections.Previous) projectModelIndex--;
            else if (direction == SlideDirections.None) projectModelIndex = 0;

            // Ensures if next is pressed while at max length, slide goes back to 0
            if (projectModelIndex > length) projectModelIndex = 0;
            // Ensures if previous is pressed while at max length, slide goes back to 0
            if (projectModelIndex < 0) projectModelIndex = length;

            selectedProjectModel = projectsModels[year][projectModelIndex];

            SwitchSelectedMedia(0);

            await InvokeAsync(StateHasChanged);
        }
    }

    private void SwitchCapstoneMedia(int key)
    {
        if (capstoneProjectModel != null)
        {
            selectedCapstoneProjectMedia = capstoneProjectModel.Medias.FirstOrDefault(t => t.Key == key);

            if (selectedCapstoneProjectMedia.IsVideo && selectedCapstoneProjectMedia.Type == FileTypes.PNG)
                selectedCapstoneProjectMedia = capstoneProjectModel.Medias.FirstOrDefault();

            isCapstoneVideoSelected = selectedCapstoneProjectMedia.IsVideo;
        }
    }

    public void SwitchSelectedMedia(int key)
    {
        if (selectedProjectModel != null)
        {
            if (!isGalleryOpened)
            {
                selectedProjectMedia = selectedProjectModel.Medias.FirstOrDefault(t => t.Key == key);

                if (selectedProjectMedia.IsVideo && selectedProjectMedia.Type == FileTypes.PNG)
                    selectedProjectMedia = selectedProjectModel.Medias.FirstOrDefault();

                isVideoSelected = selectedProjectMedia.IsVideo;
            }
            else
            {
                selectedGalleryProjectMedia = selectedProjectModel.Medias.FirstOrDefault(t => t.Key == key);
            }
        }
    }

    private void SwitchSelectedCareer(int key)
    {
        if (careerLogsModels.TryGetValue(key, out var careerLogsModel))
        {
            selectedCareerLogsModel = careerLogsModel;
        }
    }

    private void SwitchSelectedAcknowledgementType(AcknowledgementTypes acknowledgementType)
    {
        selectedAcknowledgementTypeModel = acknowledgementTypesModels
            .FirstOrDefault(t => t.AcknowledgementType == acknowledgementType);
    }

    public void ToggleGalleryView(bool state, int key = 0)
    {
        if (key != 0)
        {
            selectedGalleryProjectMedia = selectedProjectModel.Medias[key];
        }

        isGalleryOpened = state;
    }
