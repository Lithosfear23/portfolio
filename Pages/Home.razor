@if (isGalleryOpened)
{
    var mediaCount = Math.Min(displayedMedia - 1, selectedProjectModel.Medias.Count);
    var maxAvailableMedia = selectedProjectModel.Medias.Count - 1;


    <div class="fixed inset-0 bg-black/70 flex items-center justify-center z-50 transition-opacity duration-5000
        @(isGalleryOpened ? "opacity-100" : "opacity-0 pointer-events-none")"
        @onclick="() => ToggleGalleryView(false)">

        <div class="flex flex-col bg-[#39406F] rounded-xl w-[900px] max-w-[90vw] h-[400px] gap-3 p-3 transition-all duration-300
            @(isGalleryOpened
                ? "opacity-100 scale-100"
                : "opacity-0 scale-95")"
            @onclick:stopPropagation>

            TEST
            @mediaCount
            @maxAvailableMedia

            <button class="flex justify-end text-slate-300"
                    @onclick="() => ToggleGalleryView(false)">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                    fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"
                     class="icon icon-tabler icons-tabler-outline icon-tabler-x
                     cursor-pointer transition-all hover:shadow-lg hover:-translate-y-1">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                    <path d="M18 6l-12 12" /><path d="M6 6l12 12" />
                </svg>
            </button>

            <div class="flex font-body text-slate-300 text-2xl justify-center border-y">
                Gallery
            </div>

            <div class="flex-1 flex flex-col md:flex-row w-full gap-3 overflow-hidden">

                <!-- Viewer -->
                <div class="flex justify-center items-center flex-1 h-full w-full md:w-5xl">

                    <img class="max-h-full max-w-full object-contain"
                         src="@selectedGalleryProjectMedia.Source" />

                </div>

                <!-- Thumbnails -->
                <div class="flex flex-row md:flex-col gap-3 p-3 w-75 overflow-y-auto scroll-smooth scrollbar-thumb-blue-400">

                    @for (int i = mediaCount; i < maxAvailableMedia; i++)
                    {
                        var media = selectedProjectModel.Medias[i];
                        if (selectedGalleryProjectMedia.Key == selectedProjectModel.Medias[i].Key)
                        {
                            <img class="max-h-full max-w-full object-contain cursor-pointer transition-all duration-200 hover:shadow-lg
                                hover:-translate-y-1 border-b border-blue-400 shadow-xl/15 shadow-sky-300"
                                src="@media.Source"
                                @onclick="() => SwitchSelectedMedia(media.Key)" />

                        }
                        else
                        {
                            <img class="max-h-full max-w-full object-contain cursor-pointer transition-all duration-200 hover:shadow-lg
                                 hover:-translate-y-1"
                                 src="@media.Source"
                                 @onclick="() => SwitchSelectedMedia(media.Key)" />
                        }
                    }

                </div>

            </div>

        </div>

    </div>
}

